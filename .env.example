# Willy's Roofing — environment variables
#
# Copy this file to `.env.local` and fill in real values. EVERYTHING HERE IS
# OPTIONAL: with nothing set, the site still runs — the contact API
# (app/api/contact) validates each estimate request, logs it server-side, and
# reports it as "not emailed" so the UI honestly tells the visitor the team will
# follow up by phone. Set the variables below to actually deliver leads by email.
#
# NOTE: real .env files are gitignored (.env*); never commit secrets. Only this
# .env.example is tracked.

# ── Contact-form email delivery (Resend) ──────────────────────────────────────
# Read in app/api/contact/route.ts. An email is sent only when BOTH
# RESEND_API_KEY and CONTACT_INBOX are set; otherwise leads are just logged.

# Inbox that estimate requests are delivered to. (Required to enable email.)
CONTACT_INBOX=leads@willysroofing.ca

# Resend API key — create one at https://resend.com/api-keys. (Required to enable email.)
RESEND_API_KEY=

# From address for outbound lead emails. (Optional — defaults to
# noreply@willysroofing.ca.) Use a sender domain you've verified in Resend.
CONTACT_FROM="Willy's Roofing <noreply@willysroofing.ca>"
